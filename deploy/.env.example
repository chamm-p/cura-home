# ─── cura-home — Environment ───
# Kopiere zu .env und fülle die Werte aus.

# ─── Ports (Host) ───
FRONTEND_PORT=9611
BACKEND_PORT=9615

# ─── Datenbank ───
POSTGRES_DB=curahome
POSTGRES_USER=curahome
POSTGRES_PASSWORD=__change_me__

# ─── Security ───
# SECRET_KEY: signiert alle JWTs. Erzeugen:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=__change_me_64_hex__
# ENCRYPTION_KEY: Fernet-Key für verschlüsselte LLM-API-Keys. Erzeugen:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=__change_me_fernet__

# ─── App ───
# Öffentliche Frontend-URL — Ziel der QR-Codes (…/items/{id}).
PUBLIC_BASE_URL=http://localhost:9611

# ─── Dev-Login (.env-User, ohne Keycloak) ───
# Einfacher Username/Passwort-Login für lokale Entwicklung.
# In Produktion: DEV_LOGIN_ENABLED=false und OIDC nutzen.
DEV_LOGIN_ENABLED=true
DEV_USER=admin
DEV_PASSWORD=admin1234
DEV_USER_ROLE=admin

# ─── OIDC (Keycloak) ───
# Discovery-URL = Realm-Basis ODER volle well-known-URL.
#   z.B. https://keycloak.example.com/realms/home
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=cura-home
OIDC_CLIENT_SECRET=
# Muss exakt dem Redirect-URI im Keycloak-Client entsprechen.
OIDC_REDIRECT_URI=http://localhost:9611/login
OIDC_SCOPES=openid email profile
OIDC_GROUPS_CLAIM=groups
# Komma-separierte IdP-Gruppen, die Admin-Rechte erhalten.
OIDC_ADMIN_GROUPS=curahome-admins
# Bootstrap: diese E-Mails werden beim ersten Login Admin.
ADMIN_EMAILS=
